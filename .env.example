# --- إعدادات السيرفر (Server Settings) ---
PORT=5000
NODE_ENV=production
DOMAIN=alaayoussef.shop

# --- قاعدة البيانات (Local Database) ---
# يتم استخدام تخزين JSON محلي في مجلد server/data (سيتم الحفاظ عليه في Docker)

# --- بيانات المشرف (Admin Credentials) ---
# غير هذه البيانات عند البدء
ADMIN_USERNAME=admin
ADMIN_PASSWORD=adminpassword

# --- الحماية (Security) ---
# ضرووري: غير هذا المفتاح إلى سلسلة نصية عشوائية وطويلة
JWT_SECRET=yoursecretkeyhere

# --- مسارات الملفات (File Paths) ---
ARABIC_FONT_PATH=./fonts/TraditionalArabic.ttf

# --- روابط الموقع (Site URLs) ---
# استبدل بموقع السيرفر الفعلي
PUBLIC_BASE_URL=https://alaayoussef.shop
VERIFY_BASE_URL=https://alaayoussef.shop/verify

# --- إعدادات CORS ---
CORS_ORIGINS=https://alaayoussef.shop,http://localhost:5173
